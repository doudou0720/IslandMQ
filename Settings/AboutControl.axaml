<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:IslandMQ.ViewModels"
             xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
             xmlns:ci="http://classisland.tech/schemas/xaml/core"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="IslandMQ.Settings.AboutControl"
             x:DataType="vm:IslandMQSettingsViewModel">
    <StackPanel Spacing="8">
        <ci:IconText Glyph="&#xE946;" Text="关于" Margin="0 0 0 4" />

        <!-- 插件信息 -->
        <fa:SettingsExpander Header="IslandMQ"
                             Description="适用于 ClassIsland 2.x 的多操作系统远程 API 调用插件"
                             IsExpanded="True">
            <fa:SettingsExpander.IconSource>
                <fa:ImageIconSource/>
            </fa:SettingsExpander.IconSource>
            <fa:SettingsExpander.Footer>
                <TextBlock Text="版本: 0.0.1.2"
                           FontSize="12"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}"/>
            </fa:SettingsExpander.Footer>
            <fa:SettingsExpanderItem Content="基于 NetMQ 实现的轻量级消息队列服务">
            </fa:SettingsExpanderItem>
            <fa:SettingsExpanderItem Content="支持请求/响应和发布/订阅两种通信模式">
            </fa:SettingsExpanderItem>
            <fa:SettingsExpanderItem Content="跨平台支持，可在 Windows、Linux、macOS 上运行">
            </fa:SettingsExpanderItem>
        </fa:SettingsExpander>

        <!-- 协议端口信息 -->
        <fa:SettingsExpander Header="当前服务器状态"
                             Description="查看当前配置的服务器端口信息">
            <fa:SettingsExpander.IconSource>
                <ci:FluentIconSource Glyph="&#xE968;"/>
            </fa:SettingsExpander.IconSource>
            <fa:SettingsExpanderItem Content="REQ 服务器端口 (请求/响应模式)">
                <fa:SettingsExpanderItem.Footer>
                    <TextBlock Text="{Binding ReqServerPort, StringFormat='端口: {0}'}"
                               FontWeight="SemiBold"/>
                </fa:SettingsExpanderItem.Footer>
            </fa:SettingsExpanderItem>
            <fa:SettingsExpanderItem Content="PUB 服务器端口 (发布/订阅模式)">
                <fa:SettingsExpanderItem.Footer>
                    <TextBlock Text="{Binding PubServerPort, StringFormat='端口: {0}'}"
                               FontWeight="SemiBold"/>
                </fa:SettingsExpanderItem.Footer>
            </fa:SettingsExpanderItem>
        </fa:SettingsExpander>
    </StackPanel>
</UserControl>
